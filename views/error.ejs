<%- include('./partials/head') %>
<%- include('./partials/navbar') %>
<%- include('./partials/flash') %>
<main class="main-content">
<div style="min-height:65vh;display:flex;align-items:center;">
  <div class="container text-center py-5">
    <div style="font-size:clamp(5rem,15vw,8rem);font-weight:800;font-family:'Syne',sans-serif;color:var(--border);line-height:1;">
      <%= statusCode||500 %>
    </div>
    <h2 class="font-syne fw-800 mt-2" style="color:var(--ink);font-size:clamp(1.2rem,3vw,1.8rem);">
      <%= message||'Something went wrong' %>
    </h2>
    <p class="text-muted mt-2 mb-4" style="font-size:0.9rem;max-width:400px;margin:0 auto;">
      <% if (statusCode===404) { %>The page you're looking for doesn't exist or has been moved.
      <% } else { %>An unexpected error occurred. Please try again.
      <% } %>
    </p>
    <div class="d-flex gap-2 justify-content-center flex-wrap">
      <a href="/jobs" class="btn btn-accent px-4">Browse Jobs</a>
      <a href="/" class="btn-outline-ink px-4 py-2 d-inline-flex">Go Home</a>
    </div>
  </div>
</div>
</main>
<%- include('./partials/footer') %>
<%- include('./partials/scripts') %>
