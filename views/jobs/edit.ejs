<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main class="main-content">
<div class="container mt-3">
  <a href="/jobs/<%= job._id %>" class="text-decoration-none text-muted d-inline-flex align-items-center gap-1 mb-3" style="font-size:0.875rem;"><i class="bi bi-arrow-left"></i>Back to Job</a>
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card-clean p-4">
        <p class="section-label mb-1">Editing Listing</p>
        <h2 class="font-syne fw-800 mb-1" style="letter-spacing:-0.5px;color:var(--ink);">Edit Job</h2>
        <p class="text-muted mb-4" style="font-size:0.875rem;">Update your job listing details below.</p>
        <form action="/jobs/<%= job._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Job Title <span class="text-accent">*</span></label>
              <input type="text" class="form-control" name="title" value="<%= job.title %>" required />
              <div class="invalid-feedback">Job title is required.</div>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Company Name <span class="text-accent">*</span></label>
              <input type="text" class="form-control" name="companyName" value="<%= job.companyName %>" required />
              <div class="invalid-feedback">Company name is required.</div>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Job Type <span class="text-accent">*</span></label>
              <select class="form-select" name="type" required>
                <option value="Full-Time" <%= job.type==='Full-Time'?'selected':'' %>>Full-Time</option>
                <option value="Internship" <%= job.type==='Internship'?'selected':'' %>>Internship</option>
                <option value="Part-Time" <%= job.type==='Part-Time'?'selected':'' %>>Part-Time</option>
                <option value="Contract" <%= job.type==='Contract'?'selected':'' %>>Contract</option>
                <option value="Remote" <%= job.type==='Remote'?'selected':'' %>>Remote</option>
              </select>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Location</label>
              <input type="text" class="form-control" name="location" value="<%= job.location||'' %>" />
            </div>
            <div class="col-sm-6">
              <label class="form-label">Salary Range</label>
              <input type="text" class="form-control" name="salary" value="<%= job.salary||'' %>" />
            </div>
            <div class="col-sm-6">
              <label class="form-label">Experience Required</label>
              <select class="form-select" name="experience">
                <option value="Any" <%= job.experience==='Any'?'selected':'' %>>Any level</option>
                <option value="0-1 years" <%= job.experience==='0-1 years'?'selected':'' %>>0–1 years</option>
                <option value="1-3 years" <%= job.experience==='1-3 years'?'selected':'' %>>1–3 years</option>
                <option value="3-5 years" <%= job.experience==='3-5 years'?'selected':'' %>>3–5 years</option>
                <option value="5+ years" <%= job.experience==='5+ years'?'selected':'' %>>5+ years</option>
              </select>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Update Logo</label>
              <div class="file-upload-zone" onclick="document.getElementById('logoInput').click()">
                <% if (job.logo && job.logo.url) { %>
                  <img src="<%= job.logo.url %>" style="width:50px;height:50px;border-radius:8px;object-fit:cover;margin:0 auto 6px;display:block;" />
                <% } else { %>
                  <i class="bi bi-image fs-4 d-block mb-1" style="color:var(--text-muted);"></i>
                <% } %>
                <label id="logoLabel" class="file-upload-label" style="font-size:0.8rem;">Click to replace logo</label>
                <input type="file" id="logoInput" name="logo" accept="image/*" />
              </div>
            </div>
            <div class="col-12">
              <label class="form-label">Skills <span class="text-muted fw-normal">(comma separated)</span></label>
              <input type="text" class="form-control" name="skills" value="<%= job.skills||'' %>" />
            </div>
            <div class="col-12">
              <label class="form-label">Job Description <span class="text-accent">*</span></label>
              <textarea class="form-control" name="description" rows="10" required style="resize:vertical;"><%= job.description %></textarea>
              <div class="invalid-feedback">Job description is required.</div>
            </div>
          </div>
          <div class="d-flex gap-2 mt-4 flex-wrap">
            <button type="submit" class="btn btn-accent px-4 py-3"><i class="bi bi-check2 me-2"></i>Save Changes</button>
            <a href="/jobs/<%= job._id %>" class="btn-outline-ink px-4 py-3 d-inline-flex align-items-center">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
</main>
<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
