<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main class="main-content">
<div class="container mt-3">
  <a href="/jobs" class="text-decoration-none text-muted d-inline-flex align-items-center gap-1 mb-3" style="font-size:0.875rem;"><i class="bi bi-arrow-left"></i>Back to Jobs</a>
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card-clean p-4">
        <p class="section-label mb-1">New Listing</p>
        <h2 class="font-syne fw-800 mb-1" style="letter-spacing:-0.5px;color:var(--ink);">Post a Job</h2>
        <p class="text-muted mb-4" style="font-size:0.875rem;">Reach thousands of qualified candidates today.</p>
        <form action="/jobs" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Job Title <span class="text-accent">*</span></label>
              <input type="text" class="form-control" name="title" placeholder="e.g. Senior Frontend Developer" required />
              <div class="invalid-feedback">Job title is required.</div>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Company Name <span class="text-accent">*</span></label>
              <input type="text" class="form-control" name="companyName" value="<%= currentUser&&currentUser.companyName?currentUser.companyName:'' %>" placeholder="Your company" required />
              <div class="invalid-feedback">Company name is required.</div>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Job Type <span class="text-accent">*</span></label>
              <select class="form-select" name="type" required>
                <option value="" disabled selected>Select type...</option>
                <option value="Full-Time">Full-Time</option>
                <option value="Internship">Internship</option>
                <option value="Part-Time">Part-Time</option>
                <option value="Contract">Contract</option>
                <option value="Remote">Remote</option>
              </select>
              <div class="invalid-feedback">Please select a job type.</div>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Location</label>
              <input type="text" class="form-control" name="location" placeholder="e.g. New York, NY or Remote" />
            </div>
            <div class="col-sm-6">
              <label class="form-label">Salary Range</label>
              <input type="text" class="form-control" name="salary" placeholder="e.g. $80k–$120k/yr" />
            </div>
            <div class="col-sm-6">
              <label class="form-label">Experience Required</label>
              <select class="form-select" name="experience">
                <option value="Any">Any level</option>
                <option value="0-1 years">0–1 years</option>
                <option value="1-3 years">1–3 years</option>
                <option value="3-5 years">3–5 years</option>
                <option value="5+ years">5+ years</option>
              </select>
            </div>
            <div class="col-sm-6">
              <label class="form-label">Company Logo</label>
              <div class="file-upload-zone" onclick="document.getElementById('logoInput').click()">
                <img id="logoPreview" src="" alt="" style="display:none;width:56px;height:56px;border-radius:10px;object-fit:cover;margin:0 auto 6px;" />
                <i class="bi bi-image fs-4 d-block mb-1" style="color:var(--text-muted);"></i>
                <label id="logoLabel" class="file-upload-label" style="font-size:0.8rem;">Upload logo (PNG, JPG)</label>
                <input type="file" id="logoInput" name="logo" accept="image/*" />
              </div>
            </div>
            <div class="col-12">
              <label class="form-label">Skills <span class="text-muted fw-normal">(comma separated)</span></label>
              <input type="text" class="form-control" name="skills" placeholder="e.g. React, Node.js, PostgreSQL" />
            </div>
            <div class="col-12">
              <label class="form-label">Job Description <span class="text-accent">*</span></label>
              <textarea class="form-control" name="description" rows="10" placeholder="Describe the role, responsibilities, requirements..." required style="resize:vertical;"></textarea>
              <div class="invalid-feedback">Job description is required.</div>
            </div>
          </div>
          <div class="d-flex gap-2 mt-4 flex-wrap">
            <button type="submit" class="btn btn-accent px-4 py-3"><i class="bi bi-send me-2"></i>Post Job</button>
            <a href="/jobs" class="btn-outline-ink px-4 py-3 d-inline-flex align-items-center">Cancel</a>
          </div>
        </form>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card-clean p-4" style="background:var(--ink);border-color:var(--ink);">
        <h5 class="font-syne fw-700 mb-3 text-white">💡 Tips for a Great Posting</h5>
        <div style="font-size:0.83rem;line-height:1.85;color:rgba(255,255,255,0.65);">
          <p>✅ <strong style="color:white;">Be specific</strong> about role and responsibilities.</p>
          <p>✅ <strong style="color:white;">List key skills</strong> to attract the right candidates.</p>
          <p>✅ <strong style="color:white;">Mention salary</strong> — gets 40% more applicants.</p>
          <p>✅ <strong style="color:white;">Upload your logo</strong> to build brand credibility.</p>
          <p>✅ <strong style="color:white;">Describe the culture</strong> and team environment.</p>
        </div>
      </div>
    </div>
  </div>
</div>
</main>
<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
